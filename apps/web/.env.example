# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Cron endpoint secret — set this in Coolify and match in the scheduled task
CRON_SECRET=""

# Coolify scheduled task setup (Issue 10):
# Add a Scheduled Task in Coolify pointing to your deployed service.
# Command (runs daily, e.g. 0 2 * * *):
#   curl -s -o /dev/null -w "%{http_code}" \
#     -X GET https://your-domain.com/api/cron \
#     -H "Authorization: Bearer $CRON_SECRET"
# The CRON_SECRET value must match the env var set in your Coolify service.
